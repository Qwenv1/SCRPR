# Required: Admin token for API authentication
# The Netlify function checks HEALTH_API_TOKEN first, then ADMIN_API_TOKEN
HEALTH_API_TOKEN=your_admin_token_here
ADMIN_API_TOKEN=your_admin_token_here

# Required for structure/PDF actions: Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Python backend URL for stealth fetching fallback (Scrapling + PyMuPDF)
# When set, the Netlify function will retry blocked (403) requests via the Python backend
# SCRPR_BACKEND_URL=https://your-backend.example.com
